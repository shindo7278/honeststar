# Supabase (project settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — central Honeststar email account
RESEND_API_KEY=
RESEND_FROM_EMAIL="Honeststar <reminders@honeststar.co.uk>"

# Twilio — central Honeststar WhatsApp account
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM="whatsapp:+44XXXXXXXXXX"

# Paddle — billing (sandbox while testing, switch to production later)
NEXT_PUBLIC_PADDLE_ENV="sandbox"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Paddle Price IDs — one per plan (create these in Paddle Catalog > Prices)
NEXT_PUBLIC_PADDLE_PRICE_BASIC=
NEXT_PUBLIC_PADDLE_PRICE_STANDARD=
NEXT_PUBLIC_PADDLE_PRICE_PRO=

# Public app URL (used for click-tracking redirect links and Paddle return URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
